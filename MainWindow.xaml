<Window x:Class="WorkTrackLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WorkTrack Lite"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="WorkTrack Lite"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal"
                    Grid.Row="1"
                    Margin="0,0,0,20">

            <Button Content="Check In"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Command="{Binding CheckInCommand}" />

            <Button Content="Check Out"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Command="{Binding CheckOutCommand}"/>

            <Button Content="Sync Data"
                    Width="120"
                    Height="40"
                    Command="{Binding SyncCommand}" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="10">

            <DataGrid ItemsSource="{Binding Sessions}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Check In"
                                        Binding="{Binding CheckInTime}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Check Out"
                                        Binding="{Binding CheckOutTime}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="150"/>

                    <DataGridCheckBoxColumn Header="Synced"
                                            Binding="{Binding Synced}"
                                            Width="100"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</Window>